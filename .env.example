# --- SQL Server connection ---
DB_SERVER=""           # e.g. localhost  or  myserver.database.windows.net
DB_PORT="1433"
DB_NAME=""
DB_USER=""             # e.g. sa  (or an Azure SQL login)
DB_PASSWORD=""
# ODBC driver name as installed on the host (msodbcsql18 -> "ODBC Driver 18 for SQL Server")
DB_DRIVER="ODBC Driver 18 for SQL Server"
# Encrypt: required for Azure SQL. TrustServerCertificate: "true" for local/self-signed servers.
DB_ENCRYPT="true"
DB_TRUST_SERVER_CERTIFICATE="true"

SECRET_KEY=""
ALGORITHM=""

ACCESS_TOKEN_EXPIRE_MINUTES=
BACKEND_CORS_ORIGINS=

AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""

ALLOWED_HOSTS=[""]
PROXY_TRUSTED_HOSTS=""
APP_PORT=

AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER_NAME=""
